# =============================================================================
# Nexa Images — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# ---------------------------------------------------------------------------
# VITE_SITE_URL — URL pública do site (usada para canonical, OG tags e sitemap)
# Exemplos:
#   Custom domain:  https://www.nexaimages.com.br
#   GitHub Pages:   https://<usuario>.github.io/<repo>
# ---------------------------------------------------------------------------
VITE_SITE_URL=https://seu-dominio.com.br

# ---------------------------------------------------------------------------
# VITE_ZAZZLE_STORE_URL — URL base da loja na Zazzle
# Usada como fallback quando o produto não tem zazzleUrl individual.
# ---------------------------------------------------------------------------
VITE_ZAZZLE_STORE_URL=https://www.zazzle.com.br/store/nexa_images

# ---------------------------------------------------------------------------
# VITE_BASE_PATH — Base path do Vite para deploy em subdiretório
# Necessário apenas se o site ficar em subpath (ex.: GitHub Pages sem custom domain).
# Exemplo: /nexa-images-showcase/
# Se usar custom domain, deixe comentado ou use "/".
# ---------------------------------------------------------------------------
# VITE_BASE_PATH=/nexa-images-showcase/
